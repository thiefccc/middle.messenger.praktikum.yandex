{
  "name": "tapresslide",
  "version": "0.1.0",
  "private": true,
  "description": "TaPresSlide — web messenger",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "npm run build && vite preview --port 3000",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "npm run lint:ts && npm run lint:eslint && npm run lint:styles",
    "lint:ts": "tsc --noEmit",
    "lint:eslint": "eslint . --ext .ts,.tsx",
    "lint:eslint:fix": "eslint . --ext .ts,.tsx --fix",
    "lint:styles": "stylelint \"src/**/*.scss\"",
    "lint:styles:fix": "stylelint \"src/**/*.scss\" --fix"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^25.5.0",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "handlebars": "^4.7.8",
    "prettier": "^3.8.1",
    "sass": "^1.85.0",
    "stylelint": "^16.15.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.26.0",
    "vite": "^6.2.0"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
